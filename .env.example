APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production (HTTPS) example:
# APP_URL=https://hoxtan.developmentalphawizz.com
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# Default Filament admin login (used by admin:setup and AdminSeeder)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=12345678

# One-time production setup — visit /setup-admin/{token} then remove this line
# ADMIN_SETUP_TOKEN=change-this-to-a-long-random-string

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb — WebSocket live gold/silver rates for mobile
REVERB_APP_ID=hoxtan
REVERB_APP_KEY=hoxtan-reverb-key
REVERB_APP_SECRET=hoxtan-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Production example (WSS via reverse proxy):
# REVERB_HOST=hoxtan.developmentalphawizz.com
# Use domain only — no http:// or trailing slash
# REVERB_PORT=443
# REVERB_SCHEME=https

# Metals-API — live gold & silver rates (https://metals-api.com)
METALS_API_KEY=
METALS_API_BASE_URL=https://metals-api.com/api
METALS_API_GOLD_SYMBOL=VISA-24k
METALS_API_CURRENCY=INR

# Registration OTP (mobile signup)
OTP_LENGTH=4
OTP_EXPIRES_IN=300
OTP_RESEND_AFTER=30
OTP_MAX_ATTEMPTS=5
REGISTRATION_SESSION_TTL=1800
OTP_EXPOSE_IN_RESPONSE=true
MPIN_LENGTH=4
